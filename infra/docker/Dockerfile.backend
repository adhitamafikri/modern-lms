# ------------------------------------------------------------
# Stage 1: Base
# ------------------------------------------------------------
FROM oven/bun:1.2.23-alpine AS base

WORKDIR /app

COPY package.json bun.lock ./

RUN bun install

# ------------------------------------------------------------
# Stage 2: Development
# ------------------------------------------------------------
FROM base AS development

COPY . .

CMD ["bun", "dev"]

EXPOSE 8000

# ------------------------------------------------------------
# Stage 3: Production
# ------------------------------------------------------------